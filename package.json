{
  "name": "personalfinance",
  "version": "1.0.0",
  "type": "module",
  "description": "Complete Personal Finance Management Web Application - MERN Stack",
  "main": "api/index.js",

  "scripts": {
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm install && npm run build",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "install-all": "npm install && npm --prefix backend install && npm --prefix frontend install"
  },
  "keywords": [
    "finance",
    "personal-finance",
    "expense-tracker",
    "income-tracker",
    "investment-tracker",
    "loan-manager",
    "insurance-manager",
    "mern-stack"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.2",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "mongoose": "^8.19.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.8.3",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "yahoo-finance2": "^3.15.2"
  },
  "engines": {
    "node": "20.x"
  }
}
