{
    "version": 2,
    "installCommand": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "buildCommand": "cd frontend && npm run build",
    "outputDirectory": "frontend/dist",
    "env": {
        "NODE_ENV": "production"
    },
    "functions": {
        "api/index.js": {
            "maxDuration": 30,
            "memory": 1024,
            "runtime": "nodejs20.x"
        }
    },
    "routes": [
        {
            "src": "^/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "^/health/?$",
            "dest": "/api/index.js"
        },
        {
            "src": "^/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "^/(.*)",
            "dest": "/index.html"
        }
    ]
}
