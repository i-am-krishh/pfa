{
    "version": 2,
    "buildCommand": "npm run build:frontend",
    "outputDirectory": "frontend/dist",
    "installCommand": "npm install && cd backend && npm install && cd ../frontend && npm install && cd ..",
    "env": {
        "NODE_ENV": "production"
    },
    "functions": {
        "api/index.js": {
            "maxDuration": 30,
            "memory": 1024,
            "runtime": "nodejs20.x"
        }
    },
    "routes": [
        {
            "src": "^/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "^/health/?$",
            "dest": "/api/index.js"
        },
        {
            "src": "^/(?!api)(?!health)(?!assets)(?!favicon).*$",
            "dest": "/index.html",
            "status": 200
        },
        {
            "src": "^/assets/(.*)$",
            "dest": "/assets/$1"
        }
    ]
}
